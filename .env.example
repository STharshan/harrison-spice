# Copy to `.env.local`. Only `VITE_*` variables are exposed to the browser bundle.

# Deployed Harrison Spice Table Booking (Next.js) origin — no trailing slash.
# Used for: creating holds, Stripe Checkout session, confirming checkout after return to /reservations.
# Local example: Next API on port 3000
VITE_BOOKING_API_BASE_URL=http://localhost:3000
